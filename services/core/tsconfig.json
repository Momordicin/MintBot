{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "composite": true,
    "outDir": "../../out/core"
  },
  "include": ["./**/*"],
  "references": [
    { "path": "../../shared" }
  ]
}